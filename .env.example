# Скопируйте в .env и заполните своими значениями. .env в git не попадает.

# Учётные данные Kwork (используются только для первичного логина в браузере)
KWORK_LOGIN=your_email@example.com
KWORK_PASSWORD=your_password

# Groq API (генерация текста предложений)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
# Если Groq недоступен напрямую (403) — укажите URL прокси (Cloudflare Worker и т.п.)
GROQ_URL=https://api.groq.com/openai/v1/chat/completions

# CDP-эндпоинт запущенного Chrome
CDP_URL=http://localhost:29229

# Ценообразование: цена = макс. бюджет − скидка, не ниже пола
KWORK_PRICE_DISCOUNT=0.10
KWORK_PRICE_FLOOR=500

# Сколько новых заявок максимум сканировать за прогон
SCAN_CAP=80
